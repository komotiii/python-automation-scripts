# OpenWeather
OPENWEATHER_API_KEY=replace-with-your-openweather-api-key
OPENWEATHER_LAT=36.08
OPENWEATHER_LON=140.076

# Morning_Voice (VOICEVOX + schedule)
VOICEVOX_URL=http://127.0.0.1:50021
VOICEVOX_SPEAKER_ID=47
CALENDAR_EVENTS_BASE_URL=http://127.0.0.1:5000/events/
MORNING_SCHEDULE_SOURCES=3Schedule,4Job,5Univ

# CalendarFlask
GOOGLE_CALENDAR_SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_CALENDAR_LIST_FILE=calendar_list.txt
CALENDAR_FLASK_HOST=0.0.0.0
CALENDAR_FLASK_PORT=5000
