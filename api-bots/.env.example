# Discord bot configuration
DISCORD_BOT_TOKEN=replace-with-your-bot-token
DISCORD_TARGET_USER_ID=123456789012345678
DISCORD_TARGET_GUILD_ID=123456789012345678

# Google Calendar configuration
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google_calendar_service_key.json
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Optional settings
PLAYING_BOT_LOG_FILE=logs/activity_log.txt
PLAYING_BOT_CHECK_INTERVAL_SECONDS=60
PLAYING_BOT_TIMEZONE=Asia/Tokyo

# Tukunavi monitor configuration
TSUKUNAVI_DISCORD_CHANNEL_ID=123456789012345678
TSUKUNAVI_URL=https://tsukunavi.com/forums/forum/%E3%82%A2%E3%83%AB%E3%83%90%E3%82%A4%E3%83%88/
TSUKUNAVI_SAVE_FILE=data/posts.json
TSUKUNAVI_CHECK_INTERVAL_SECONDS=300
TSUKUNAVI_RETRY_SECONDS=30
TSUKUNAVI_REQUEST_TIMEOUT_SECONDS=20
TSUKUNAVI_SKIP_INITIAL_NOTIFY=true
TSUKUNAVI_NOTIFY_ON_START=true
