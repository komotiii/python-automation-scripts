# OpenWeather API
OPENWEATHER_API_KEY=replace-with-your-openweather-api-key
OPENWEATHER_LAT=36.083
OPENWEATHER_LON=140.076
OPENWEATHER_LANG=en

# Google Calendar OAuth
GOOGLE_CALENDAR_OAUTH_CREDENTIALS=credentials.json
GOOGLE_CALENDAR_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary

# Sync behavior
WEATHER_TIMEZONE=Asia/Tokyo
WEATHER_FORECAST_HOURS=24
WEATHER_SLOT_HOURS=3
WEATHER_REPLACE_AFTER_HOURS=3
WEATHER_EVENT_PREFIX=[Weather]
