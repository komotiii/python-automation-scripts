# Google Calendar API configuration
GOOGLE_CALENDAR_OAUTH_CREDENTIALS=credentials.json
# OAuth token file generated after first login.
GOOGLE_CALENDAR_TOKEN_FILE=token.json

# Default target calendar.
GOOGLE_CALENDAR_ID=primary

# Sum_calendar.py
GOOGLE_CALENDAR_SERVICE_ACCOUNT_FILE=service_account.json
# Calendar list file: one line = name,calendar_id
GOOGLE_CALENDAR_LIST_FILE=calendar_list.txt
